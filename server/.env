PORT=5001
MONGO_URI=mongodb://localhost:27017/familyvault
CLIENT_URL=http://localhost:5173
USE_MOCK_AUTH=true

# Add Cloudinary credentials here to enable cloud hosting.
# If left blank, the server automatically saves images locally inside "server/uploads/"
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Add Firebase Service Account JSON absolute path here to enable strict Firebase verification.
# If left blank, server falls back to decoding Firebase token JWT payloads directly.
FIREBASE_SERVICE_ACCOUNT=
